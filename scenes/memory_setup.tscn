[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://scenes/memory_setup.gd" id="1"]
[ext_resource type="PackedScene" path="res://scenes/animated_background.tscn" id="2"]
[ext_resource type="PackedScene" path="res://scenes/difficulty_selector.tscn" id="3"]

[node name="MemorySetup" type="Control"]
layout_mode = 3
anchors_preset = 15
